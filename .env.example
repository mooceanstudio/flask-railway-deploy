# Copy to `.env` for local development:  cp .env.example .env
# `.env` is git-ignored and is loaded automatically via python-dotenv.

# --- Core ---------------------------------------------------------------------

# Selects the config class: development | production | testing
# On Railway, set this to `production`.
FLASK_ENV=development

# Alternative to FLASK_ENV; takes precedence if set. Same allowed values.
# APP_SETTINGS=development

# Flask entry point for the `flask` CLI (used by `flask db upgrade`).
FLASK_APP=app:create_app

# Secret used to sign sessions/flash messages. MUST be set in production.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# --- Database -----------------------------------------------------------------

# Full SQLAlchemy/Postgres URL. Leave unset locally to use a SQLite file.
# On Railway, reference the Postgres plugin so it is injected automatically:
#   DATABASE_URL=${{ Postgres.DATABASE_URL }}
# Legacy `postgres://` URLs are normalized to `postgresql+psycopg2://` in code.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Server -------------------------------------------------------------------

# Port the server binds to. Railway injects this automatically; do not hardcode.
PORT=8000

# gunicorn worker process count. A common rule of thumb is (2 x CPU) + 1.
WEB_CONCURRENCY=2
